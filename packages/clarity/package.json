{
  "name": "@crumbleerp/clarity",
  "version": "0.1.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nuxt": {
      "types": "./dist/nuxt/index.d.ts",
      "default": "./dist/nuxt/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "pub": "pnpm publish --access public"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8"
  },
  "peerDependencies": {
    "nuxt": "^4.4.8",
    "vue": "^3.5"
  },
  "devDependencies": {
    "nuxt": "^4.4.8",
    "typescript": "^6.0.3",
    "vue": "^3.5"
  }
}
