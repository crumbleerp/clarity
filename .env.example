DATABASE_URL=postgresql://user:pass@host:port/clarity
DATASET=production
ROOT_USERNAME=admin
ROOT_PASSWORD=admin
NUXT_SESSION_SECRET=some-random-secret-at-least-32-chars-long

# Comma-separated list of origins allowed to call /v1/data/* from the browser.
# Use "*" to allow all origins (not recommended for production).
NUXT_CORS_ORIGINS=https://example.com,https://app.example.com

# Public API base URL for the Playground and future client requests.
# Leave empty to use the same origin.
BASE_URL=

# S3 Storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=clarity-bucket
S3_ACCESS_KEY=access-key
S3_SECRET_KEY=secret-key
S3_PUBLIC_URL=https://cdn.example.com
